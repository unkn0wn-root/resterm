# Serve these mocks with `resterm mock _examples/mocks.http`, or open this file
# in the TUI and press `g Shift+M`.
# @const mock.base http://127.0.0.1:8080

### Health
# @mock method=GET path=/health name=healthy default=true
HTTP/1.1 200 OK
Content-Type: application/json

{"status":"ok"}

### Payment declined
# @mock method=POST path=/payments name=declined
# @match query={"mode":"decline"} headers={"X-Tenant":"demo"} json={"amount":0}
HTTP/1.1 422 Unprocessable Entity
Content-Type: application/json

{"error":"amount must be positive"}

### Payment accepted
# @mock method=POST path=/payments name=accepted default=true latency=150ms
HTTP/1.1 202 Accepted
Content-Type: application/json
X-Provider: sandbox

{"id":"pay_123","status":"pending"}

### User fixture
# @mock method=GET path=/users/{id} name=user default=true
HTTP/1.1 200 OK
Content-Type: application/json

< ./mock-user.json

### Interpolated profile
# @mock method=GET path=/profiles/{id}
HTTP/1.1 200 OK
Content-Type: application/json
X-Request-ID: {{$uuid}}

{"id":{{json.path.id}},"generatedAt":"{{$timestampISO8601}}"}

### Poll payment
# @mock method=GET path=/payments/{id} sequence=polling sequence-key=path.id
HTTP/1.1 503 Service Unavailable
Retry-After: 1

{"id":{{json.path.id}},"status":"pending"}
---
HTTP/1.1 503 Service Unavailable
Retry-After: 1

{"id":{{json.path.id}},"status":"pending"}
---
HTTP/1.1 200 OK
Content-Type: application/json

{"id":{{json.path.id}},"status":"completed"}

### Payment webhook
# @mock method=POST path=/webhooks/payment
# @match headers={"Authorization":{"prefix":"Bearer "},"X-Correlation-ID":{"present":true}} json={"status":"completed"}
# @expect calls=1
HTTP/1.1 204 No Content

### Payment webhook rejected
# @mock method=POST path=/webhooks/payment name=rejected default=true
HTTP/1.1 401 Unauthorized
Content-Type: application/json

{"error":"missing or invalid webhook credentials"}

### Per-key rate limit
# @mock method=GET path=/quota sequence=quota sequence-key=header.X-Api-Key
HTTP/1.1 200 OK
Content-Type: application/json

{"remaining":1}
---
HTTP/1.1 200 OK
Content-Type: application/json

{"remaining":0}
---
HTTP/1.1 429 Too Many Requests
Retry-After: 60
Content-Type: application/json

{"error":"quota exhausted for this API key"}

### Legacy endpoint must stay unused
# @mock method=GET path=/v1/legacy
# @expect calls=0
HTTP/1.1 410 Gone
Content-Type: application/json

{"error":"use /payments instead"}

### Fallback for unmocked GET paths
# @mock method=GET path=/{rest...} default=true
HTTP/1.1 404 Not Found
Content-Type: application/json

{"error":"no mock for this path","path":{{json.path.rest}}}

### Poll payment until it completes
# @name poll-payment
GET {{mock.base}}/payments/pay_42

### Spend the quota for one API key
# @name spend-quota
GET {{mock.base}}/quota
X-Api-Key: demo-key

### Deliver the payment webhook
# The mock.* assertion needs the TUI-owned server (`g Shift+M`).
# @name deliver-webhook
# @assert mock.received({method:"POST", path:"/webhooks/payment", json:{status:"completed"}})
POST {{mock.base}}/webhooks/payment
Authorization: Bearer demo-token
X-Correlation-ID: {{$uuid}}
Content-Type: application/json

{"status":"completed"}
